<Window x:Class="Login.Cadastro"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:Login"
        mc:Ignorable="d"
        Title="Cadastro" Height="450" Width="800">
    <Grid>
        <StackPanel>
            <TextBlock
                Text="Cadastro de usuário"
                FontSize="32"
                TextAlignment="Center"
                Margin="0, 0, 0, 20"/>
            <TextBlock Text="Nome de usuário" />
            <TextBox Height="25" FontSize="16" x:Name="tbUsuario" />
            <TextBlock Text="senha" />
            <TextBox Height="25" FontSize="16" x:Name="tbSenha" />
            <Button Content= "Primeiro Cadastro" Click="Pcadastro"/>
            
        </StackPanel>
    </Grid>
</Window>
