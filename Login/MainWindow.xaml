<Window x:Class="Login.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Background= "BlueViolet">
        <StackPanel Margin="20">
            <TextBlock Text="Nome de Usuário" FontSize="16"  Width= "400" Foreground="Lime" Margin ="0,0,0,10"/>
            <TextBox Background="Lime" Margin ="0,0,0,10" Height="25" Width= "400" FontSize="16" x:Name="tbUsuario" />

            <TextBlock Text="Senha" FontSize="16" Width= "400" Foreground="Lime" Margin ="0,0,0,10"/>
            <TextBox Background="Lime" Margin ="0,0,0,50" Width= "400" FontSize="16" x:Name="tbSenha" />

            <Button Background="Lime" Margin ="0,0,0,20"  Height="25" Width= "200" Content="Fazer login" Click="BotaoLogin" Foreground="BlueViolet" />
            <Button Background="Lime" Height="25" Width= "200" Content="Cadastre-se" Click="BotaoCadastro"  Foreground="BlueViolet"/>
            
        </StackPanel>
    </Grid>
</Window>